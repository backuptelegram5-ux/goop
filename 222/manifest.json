{
   "action": {
      "name": "__MSG_start_inv__"
   },
   "background": {
      "service_worker": "background.js"
   },
   "default_locale": "en",
   "description": "__MSG_descr_inv__",
   "homepage_url": "https://www.invitelikecomment.com/",
   "host_permissions": [ "https://*.facebook.com/*" ],
   "icons": {
