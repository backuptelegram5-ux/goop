      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Invite fans and post likers in Facebook™",
   "options_page": "options.html",
   "permissions": [ "storage", "activeTab", "scripting", "alarms" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2026.05.10",
   "web_accessible_resources": [ {
      "matches": [ "https://*.facebook.com/*" ],
      "resources": [ "content.css", "fonts/roboto-latin-400.woff2", "fonts/roboto-latin-700.woff2", "options.html", "comment_sender.js", "postTextNow.js", "forceReload.js", "how-to-select-posts.png" ]
   } ]
